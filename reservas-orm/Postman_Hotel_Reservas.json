  },
  "item": [
    {
      "name": "Hoteles (/api/hoteles)",
      "item": [
        {
          "name": "1. Obtener todos los hoteles",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:3000/api/hoteles"
          }
        },
        {
          "name": "2. Obtener hotel por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:3000/api/hoteles/1"
          }
        },
        {
          "name": "3. Crear un nuevo hotel",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Hotel Primavera\",\n  \"direccion\": \"Av. de las Flores 40\",\n  \"estrellas\": 5,\n  \"telefono\": \"555-3456\"\n}"
            },
            "url": "http://localhost:3000/api/hoteles"
          }
        },
        {
          "name": "4. Actualizar un hotel",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Hotel Primavera Editado\",\n  \"direccion\": \"Av. de las Flores 40 Modificada\",\n  \"estrellas\": 4,\n  \"telefono\": \"555-0000\"\n}"
            },
            "url": "http://localhost:3000/api/hoteles/1"
          }
        }
      ]
    },
